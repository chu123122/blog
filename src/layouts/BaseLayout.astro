---
import "../styles/global.css";

export interface Props {
  title?: string;
  description?: string;
}

const { title = "chu's Blog", description = "简单记录下学习过程中的笔记" } = Astro.props;
const currentPath = Astro.url.pathname;
const base = import.meta.env.BASE_URL;
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title}</title>
    <link rel="icon" href={`${base}images/%E5%A4%B4%E5%83%8F.jpg`} />
    <link rel="preconnect" href="https://fonts.googleapis.cn" />
    <link rel="preconnect" href="https://fonts.gstatic.cn" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.cn/css2?family=Noto+Serif+SC:wght@400;600;700;900&family=Noto+Sans+SC:wght@300;400;500;700&family=Zen+Old+Mincho:wght@400;700&family=Shippori+Mincho:wght@400;600;800&family=Fira+Code:wght@400;500&display=swap"
    />
    <link
      rel="stylesheet"
      href="https://s4.zstatic.net/ajax/libs/font-awesome/6.4.2/css/all.min.css"
    />
  </head>
  <body>
    <!-- 花瓣层 -->
    <div class="petal-layer" id="petal-layer"></div>

    <!-- 竖排装饰 -->
    <div class="vertical-deco">春の花びらが風に散る　——　楽酌の記録</div>

    <!-- 页面容器 -->
    <div class="page-wrap">
      <!-- 导航栏 -->
      <nav class="navbar">
        <a class="navbar__logo" href={base}>楽酌</a>
        <button class="navbar__toggle" id="menu-toggle" aria-label="菜单">
          <i class="fa-solid fa-bars"></i>
        </button>
        <div class="navbar__links" id="nav-links">
          <a href={base} class={currentPath === base || currentPath === base.slice(0,-1) ? "active" : ""}>文章</a>
          <a href={`${base}archives/`} class={currentPath.includes("archives") ? "active" : ""}>归档</a>
          <a href={`${base}about/`} class={currentPath.includes("about") ? "active" : ""}>关于</a>
        </div>
      </nav>

      <!-- 主内容 -->
      <main class="animate-fade-up">
        <slot />
      </main>

      <!-- 页脚 -->
      <footer class="footer">
        <!-- 音乐播放器 -->
        <div class="footer__player" id="footer-player">
          <div class="footer__player-wave" id="player-wave">
            <span></span><span></span><span></span><span></span><span></span>
          </div>
          <div class="footer__player-meta">
            <span class="footer__player-track" id="player-track">暂无音乐</span>
            <span class="footer__player-time" id="player-time"></span>
          </div>
          <div class="footer__player-controls">
            <button class="footer__player-btn" id="player-prev" title="上一曲">‹</button>
            <button class="footer__player-btn footer__player-btn--main" id="player-toggle" title="播放">▷</button>
            <button class="footer__player-btn" id="player-next" title="下一曲">›</button>
          </div>
          <div class="footer__player-bar" id="player-bar" title="点击跳转">
            <div class="footer__player-fill" id="player-fill"></div>
          </div>
          <audio id="bg-audio" preload="none"></audio>
        </div>

        <p class="footer__text">&copy; 2024 — 2026 楽酌</p>
        <p class="footer__ghost">すべての言葉は、いつか誰かに届く</p>
      </footer>
    </div>

    <!-- 花瓣生成 -->
    <script>
      (function () {
        const container = document.getElementById("petal-layer");
        if (!container) return;
        const colors = [
          "rgba(244,217,208,0.35)",
          "rgba(232,160,144,0.22)",
          "rgba(196,123,107,0.18)",
          "rgba(200,185,175,0.18)",
        ];
        for (let i = 0; i < 12; i++) {
          const p = document.createElement("div");
          p.className = "petal";
          p.style.left = 3 + Math.random() * 94 + "%";
          p.style.background = colors[i % 4];
          const s = 6 + Math.random() * 10;
          p.style.width = s + "px";
          p.style.height = s * 1.3 + "px";
          p.style.animationDuration = 13 + Math.random() * 13 + "s";
          p.style.animationDelay = -Math.random() * 20 + "s";
          container.appendChild(p);
        }
      })();
    </script>

    <!-- 移动端菜单 -->
    <script>
      const toggle = document.getElementById("menu-toggle");
      const links = document.getElementById("nav-links");
      if (toggle && links) {
        toggle.addEventListener("click", () => {
          links.classList.toggle("open");
        });
      }
    </script>

    <!-- 音乐播放器 -->
    <script>
      // ================================================
      // 🎵 歌单配置 — 在这里添加你的音乐
      // src: 音频文件放到 public/music/ 目录下，填写 /music/文件名.mp3
      //      也可以填写完整的外链 URL
      // ================================================
      const PLAYLIST: { title: string; src: string }[] = [
        { title: "だから僕は音楽を辞めた · ヨルシカ", src: "/music/yorushika-dakara.mp3" },
        // 继续加歌：把 mp3 放到 public/music/ 目录，照这个格式填就行
      ];
      // ================================================

      const audio = document.getElementById("bg-audio") as HTMLAudioElement | null;
      const trackEl = document.getElementById("player-track");
      const timeEl = document.getElementById("player-time");
      const toggleBtn = document.getElementById("player-toggle");
      const prevBtn = document.getElementById("player-prev");
      const nextBtn = document.getElementById("player-next");
      const fill = document.getElementById("player-fill");
      const bar = document.getElementById("player-bar");
      const wave = document.getElementById("player-wave");
      const playerEl = document.getElementById("footer-player");

      let idx = 0;
      let playing = false;

      function fmt(s: number) {
        const m = Math.floor(s / 60);
        const sec = String(Math.floor(s % 60)).padStart(2, "0");
        return `${m}:${sec}`;
      }

      function loadTrack(i: number) {
        if (!PLAYLIST.length || !audio) return;
        audio.src = PLAYLIST[i].src;
        if (trackEl) trackEl.textContent = PLAYLIST[i].title;
        if (fill) fill.style.width = "0%";
        if (timeEl) timeEl.textContent = "";
      }

      function setPlaying(state: boolean) {
        playing = state;
        if (toggleBtn) toggleBtn.textContent = state ? "⏸" : "▷";
        if (toggleBtn) toggleBtn.title = state ? "暂停" : "播放";
        if (wave) wave.classList.toggle("playing", state);
      }

      function doPlay() {
        audio?.play().then(() => setPlaying(true)).catch(() => {});
      }

      function doPause() {
        audio?.pause();
        setPlaying(false);
      }

      // 歌单为空时隐藏播放器
      if (!PLAYLIST.length) {
        if (playerEl) playerEl.style.display = "none";
      } else {
        // 只有一首歌时隐藏切换按钮
        if (PLAYLIST.length === 1) {
          if (prevBtn) (prevBtn as HTMLElement).style.display = "none";
          if (nextBtn) (nextBtn as HTMLElement).style.display = "none";
        }
        loadTrack(0);
      }

      toggleBtn?.addEventListener("click", () => { playing ? doPause() : doPlay(); });

      prevBtn?.addEventListener("click", () => {
        idx = (idx - 1 + PLAYLIST.length) % PLAYLIST.length;
        loadTrack(idx);
        if (playing) doPlay();
      });

      nextBtn?.addEventListener("click", () => {
        idx = (idx + 1) % PLAYLIST.length;
        loadTrack(idx);
        if (playing) doPlay();
      });

      audio?.addEventListener("timeupdate", () => {
        if (!audio.duration) return;
        const pct = (audio.currentTime / audio.duration) * 100;
        if (fill) fill.style.width = pct + "%";
        if (timeEl) timeEl.textContent = `${fmt(audio.currentTime)} / ${fmt(audio.duration)}`;
      });

      audio?.addEventListener("ended", () => {
        idx = (idx + 1) % PLAYLIST.length;
        loadTrack(idx);
        doPlay();
      });

      bar?.addEventListener("click", (e) => {
        if (!audio?.duration) return;
        const rect = bar.getBoundingClientRect();
        audio.currentTime = ((e.clientX - rect.left) / rect.width) * audio.duration;
      });
    </script>
  </body>
</html>
